---
import GithubSlugger from "github-slugger";

import BaseLayout from "../../layouts/BaseLayout.astro";

import { getCollection } from "astro:content";

import "../../styles/components/blog.css";

import QuickSummary from "../../components/blog/QuickSummary.astro";
import "../../styles/components/blog/blog-summary.css";

import AutoFAQ from "../../components/blog/AutoFAQ.astro";
import "../../styles/components/blog/blog-faq.css";

import RelatedResources from "../../components/blog/RelatedResources.astro";

import { marked } from "marked";

/* -------------------------
   Get posts
-------------------------- */
export async function getStaticPaths() {
  const posts = await getCollection("blog");

  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post }
  }));
}

const { post } = Astro.props;

console.log("POST DATA:", post.data);

/* -------------------------
   Related posts
-------------------------- */
const allPosts = await getCollection("blog");

const relatedPosts = allPosts
  .filter((item) => item.id !== post.id)
  .filter((item) => item.data.category === post.data.category)
  .slice(0, 3);

/* -------------------------
   Basic data
-------------------------- */
const { title, description, publishDate, category, featuredImage } = post.data;

const articleBody = post.body ?? "";
const articleHtml = marked.parse(articleBody, {
  headerIds: true,
  headerPrefix: ""
});
/* -------------------------
  FAQ
-------------------------- */

const faqItems = post.data.faq ?? [];

/* -------------------------
   TOC generation
-------------------------- */
import { marked } from "marked";

const slugger = new GithubSlugger();

marked.use({
  headerIds: true,
  headerPrefix: ""
});

const toc =
  articleBody.match(/^##\s+(.+)$/gm)?.map((line) => {
    const text = line.replace("##", "").trim();

    return {
      text,
      id: slugger.slug(text)
    };
  }) ?? [];
/* -------------------------
   Schema
-------------------------- */
const faqSchema =
  faqItems.length > 0
    ? {
        "@context": "https://schema.org",
        "@type": "FAQPage",
        mainEntity: faqItems.map((item) => ({
          "@type": "Question",
          name: item.question,
          acceptedAnswer: {
            "@type": "Answer",
            text: item.answer
          }
        }))
      }
    : null;

const authorSchema = {
  "@context": "https://schema.org",
  "@type": "Person",
  name: "Win-Win Stone Team",
  jobTitle: "Stone Manufacturing Consultant",
  worksFor: {
    "@type": "Organization",
    name: "Win-Win Stone"
  }
};

const articleSchema = {
  "@context": "https://schema.org",
  "@type": "Article",
  headline: title,
  description,
  datePublished: new Date(publishDate).toISOString(),
  author: {
    "@type": "Person",
    name: "Win-Win Stone Team"
  },
  publisher: {
    "@type": "Organization",
    name: "Win-Win Stone"
  },
  image: featuredImage ? [featuredImage] : []
};
---

<!-- Schema -->
{faqSchema && (
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
)}

<script type="application/ld+json" set:html={JSON.stringify(authorSchema)} />
<script type="application/ld+json" set:html={JSON.stringify(articleSchema)} />

<!-- Reading progress -->
<div id="reading-progress"></div>

<script>
  const progress = document.getElementById("reading-progress");

  window.addEventListener("scroll", () => {
    const total =
      document.documentElement.scrollHeight -
      document.documentElement.clientHeight;

    const current = window.scrollY;

    const percent = (current / total) * 100;

    if (progress) {
      progress.style.width = `${percent}%`;
    }
  });
</script>

<BaseLayout title={title} description={description}>
  <section class="blog-post">
    <div class="container">

      <!-- Breadcrumb -->
      <nav class="breadcrumb">
        <a href="/">Home</a>
        <span>/</span>
        <a href="/blog/">Blog</a>
        <span>/</span>
        <span>{title}</span>
      </nav>

      <!-- Header -->
      <header class="post-header">
        <span class="post-category">{category}</span>
        <h1>{title}</h1>

        <p class="post-meta">
          {new Date(publishDate).toLocaleDateString("en-US", {
            year: "numeric",
            month: "long",
            day: "numeric"
          })}
          <div class="."></div>
          6 Min Read
        </p>
      </header>

      <!-- Featured Image -->
      <img class="featured-image" src={featuredImage} alt={title} />

      <!-- Layout -->
      <section class="post-layout">

        <!-- MAIN -->
        <article class="post-content">

          <QuickSummary items={post.data.summary ?? []} />

          <div set:html={articleHtml} />

          <!-- FAQ -->
          {faqItems.length > 0 && (
            <AutoFAQ items={faqItems} />
          )}


          <!-- Related Resources -->

          {console.log("RELATED:", post.data.relatedResources)}

         
           
          <RelatedResources items={post.data.relatedResources ?? []} />

      

          <!-- Related Posts -->
          {relatedPosts.length > 0 && (
            <section class="related-posts">
              <h2>Related Articles</h2>

              <div class="related-post-grid">
                {relatedPosts.map((item) => (
                  <a href={`/blog/${item.id}/`} class="related-post-card">
                    <h3>{item.data.title}</h3>
                    <p>{item.data.description}</p>
                  </a>
                ))}
              </div>
            </section>
          )}

        </article>

        <!-- SIDEBAR -->
        <aside class="post-sidebar">

          <!-- TOC -->
          <div class="sidebar-card toc-card">
            <h3>On This Page</h3>
            <ul class="toc-list">
              {toc.map((item) => (
                <li>
                  <a href={`#${item.id}`}>{item.text}</a>
                </li>
              ))}
            </ul>
          </div>

          <!-- Categories -->
          <div class="sidebar-card">
            <h3>Popular Categories</h3>
            <ul>
              <li><a href="/stone-sinks/">Stone Sinks</a></li>
              <li><a href="/stone-tables/">Stone Tables</a></li>
              <li><a href="/stone-bathtubs/">Stone Bathtubs</a></li>
            </ul>
          </div>

          <!-- Trust -->
          <div class="sidebar-card author-trust">
            <h3>Author & Trust</h3>
            <p>Win-Win Stone Team</p>

            <ul>
              <li>15+ Years Industry Experience</li>
              <li>OEM & ODM Manufacturing</li>
              <li>Exported To 30+ Countries</li>
              <li>Custom Stone Project Support</li>
            </ul>
          </div>

          <!-- CTA -->
          <div class="sidebar-card review-card">
            <h3>Free Stone Project Review</h3>
            <p>
              Send your drawings, dimensions or reference images.
            </p>

            <a href="/contact/" class="sidebar-button">
              Request Review
            </a>
          </div>

        </aside>

      </section>
    </div>
  </section>
</BaseLayout>
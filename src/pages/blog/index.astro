---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

const posts = await getCollection("blog");

const latestPosts = posts.slice(0, 3);

---
<BaseLayout
  title="Blog"
  description="Stone furniture articles, materials knowledge, and design guides."
>

  <section class="blog-list">
    <div class="container">
      <nav class="breadcrumb">
        <a href="/">Home</a>
        <span>/</span>
        <span>Blog</span>
      </nav>
      <section class="blog-hero">

       <span class="eyebrow">
          Stone Knowledge Center
       </span>

       <h1>
          Stone Knowledge,Material Guides & Trends
       </h1>

       <p>
          Expert resources covering stone furniture,
          natural stone materials,
          custom manufacturing,
          and architectural applications.
       </p>

</section>

    <section class="blog-topics">


    <h2 class="section-title">
       Featured Guides
    </h2>

      <div class="topic-grid">

      <a class="topic-card upcoming-guide">

       <span class="guide-title">
         Stone Table Design Guide
       </span>

       <span class="guide-link">
         Coming Soon
       </span>

      </a>

    <a
      href="/blog/how-to-choose-the-right-stone-for-a-custom-bathroom-sink/"
      class="topic-card"
    >

     <span class="guide-title">
        Stone Sink Buying Guide
     </span>

     <span class="guide-link">
       Read Article →
     </span>

    </a>


   <a class="topic-card upcoming-guide">

    <span class="guide-title">
      OEM Stone Furniture Guide
    </span>

    <span class="guide-link">
      Coming Soon
    </span>

   </a>

  </div>

</section>

<section class="latest-posts">

  <div class="section-heading">

    <h2>Latest Articles</h2>

  </div>

  <div class="post-grid">

    {latestPosts.map((post) => (

      <article class="post-card">

        <a href={`/blog/${post.id}/`}>

          <img
            src={post.data.featuredImage}
            alt={post.data.title}
          />

          <div class="post-content">

            <span class="post-category">
              {post.data.category}
            </span>

            <h3>
              {post.data.title}
            </h3>

            <p>
              {post.data.description}
            </p>

            <span class="read-more">
              Read Guide →
            </span>

          </div>

        </a>

      </article>

    ))}

  </div>

</section>

<section class="blog-cta">

  <h2>Need Custom Stone Products For Your Next Project?</h2>


  <p>
    From stone sinks and bathtubs to custom
    furniture and architectural stonework,
    our team helps architects, designers,
    wholesalers and project buyers turn
    concepts into finished products.
  </p>

  <div class="cta-actions">

    <a
      href="/contact/"
      class="cta-button"
    >
      Request A Quote
    </a>

    <a
      href="/stone-sinks/"
      class="cta-secondary"
    >
      View Stone Collections
    </a>

  </div>

</section>

    </div>
  </section>
</BaseLayout>


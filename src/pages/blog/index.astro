---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

const posts = await getCollection("blog");
---

<BaseLayout
  title="Blog"
  description="Stone furniture articles, materials knowledge, and design guides."
>
  <section class="blog-list">
    <div class="container">
      <nav class="breadcrumb">
        <a href="/">Home</a>
        <span>/</span>
        <span>Blog</span>
      </nav>
      <h1>Blog</h1>
      <p>Industry insights, material guides, and custom stone furniture trends.</p>

      {posts.length ? (
        <div class="post-grid">
          {posts.map((post) => (
            <article class="post-card">
              <a href={`/blog/${post.slug}/`}>
                <h2>{post.data.title}</h2>
                <p>{post.data.description}</p>
              </a>
            </article>
          ))}
        </div>
      ) : (
        <p>博客内容正在准备中，欢迎稍后回来查看。</p>
      )}
    </div>
  </section>
</BaseLayout>

<style>
.blog-list {
  padding: 80px 0;
}
.post-grid {
  display: grid;
  gap: 24px;
  margin-top: 40px;
}
.post-card {
  border: 1px solid rgba(0,0,0,.08);
  padding: 24px;
}
.post-card a {
  color: inherit;
  text-decoration: none;
}
.post-card h2 {
  margin-bottom: 14px;
}
</style>

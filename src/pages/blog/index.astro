---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

const posts = await getCollection("blog");

const latestPosts = posts.slice(0, 3);

---
<BaseLayout
  title="Blog"
  description="Stone furniture articles, materials knowledge, and design guides."
>

  <section class="blog-list">
    <div class="container">
      <nav class="breadcrumb">
        <a href="/">Home</a>
        <span>/</span>
        <span>Blog</span>
      </nav>
      <section class="blog-hero">

       <span class="eyebrow">
          Stone Knowledge Center
       </span>

       <h1>
          Stone Design Insights,
          Material Guides &
          Industry Trends
       </h1>

       <p>
          Expert resources covering stone furniture,
          natural stone materials,
          custom manufacturing,
          and architectural applications.
       </p>

</section>

    <section class="blog-topics">

  <h2>Explore Topics</h2>

  <div class="topic-grid">

    <a href="#" class="topic-card">
      <span>Stone Tables</span>
    </a>

    <a href="#" class="topic-card">
      <span>Stone Sinks</span>
    </a>

    <a href="#" class="topic-card">
      <span>Stone Bathtubs</span>
    </a>

    <a href="#" class="topic-card">
      <span>Fireplace Surrounds</span>
    </a>

    <a href="#" class="topic-card">
      <span>Custom Furniture</span>
    </a>

  </div>

</section>

<section class="latest-posts">

  <div class="section-heading">

    <h2>Latest Articles</h2>

  </div>

  <div class="post-grid">

    {latestPosts.map((post) => (

      <article class="post-card">

        <a href={`/blog/${post.id}/`}>

          <img
            src={post.data.featuredImage}
            alt={post.data.title}
          />

          <div class="post-content">

            <span class="post-category">
              {post.data.category}
            </span>

            <h3>
              {post.data.title}
            </h3>

            <p>
              {post.data.description}
            </p>

          </div>

        </a>

      </article>

    ))}

  </div>

</section>

<section class="blog-cta">

  <h2>
    Need Custom Stone Furniture?
  </h2>

  <p>
    Discuss your project with our team and
    receive tailored stone solutions.
  </p>

  <a
    href="/contact/"
    class="cta-button"
  >
    Request A Quote
  </a>

</section>

    </div>
  </section>
</BaseLayout>


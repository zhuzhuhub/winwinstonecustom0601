---
import BaseLayout from "../../layouts/BaseLayout.astro";

import ProductHero from "../../components/product/ProductHero.astro";
import ProductSpecifications from "../../components/product/ProductSpecifications.astro";
import ProductInquiryCTA from "../../components/product/ProductInquiryCTA.astro";
import RelatedProducts from "../../components/product/RelatedProducts.astro";
import ProductFeatures from "../../components/product/ProductFeatures.astro";
// 动态生成路径
export async function getStaticPaths() {
  const modules = import.meta.glob("../../content/products/**/*.md", { eager: true });
  return Object.keys(modules)
    .filter(key => key.includes("stone-tables"))
    .map(key => {
      const slug = key.split("/").pop()?.replace(".md", "");
      return { params: { slug } };
    });
}

const slug = Astro.params.slug;

// 顶层模块读取
const allModules = import.meta.glob("../../content/products/**/*.md", { eager: true });
const moduleKey = Object.keys(allModules).find(key => key.includes(`stone-tables/${slug}`));

if (!moduleKey) {
  throw Astro.redirect("/404");
}

const module = allModules[moduleKey] as {frontmatter: any;Content: any;};

const { frontmatter, Content } = module;

// 解构 frontmatter，变量名统一
const {
  title,
  description,

  featuredImage,
  featureImage,
  gallery,

  seoTitle,
  seoDescription,

  categoryLabel,
  heroBadges,
  keyFeatures,

  material,
  finish,

  moq,
  leadTime

} = frontmatter;

const siteUrl = import.meta.env.SITE || 'https://winwinstonecustom.com';

function absUrl(path: string) {
  if (!path) return undefined;
  if (/^https?:\/\//.test(path)) return path;
  return siteUrl.replace(/\/$/, '') + (path.startsWith('/') ? path : '/' + path);
}

const breadcrumbs = [
  { name: 'Home', url: siteUrl + '/' },
  { name: 'Stone Tables', url: siteUrl + '/stone-tables/' },
  { name: title, url: `${siteUrl}/stone-tables/${slug}` }
];

const allProducts =
  Object.values(allModules);


const productForLd = {
  name: title,
  slug: `stone-tables/${slug}`,
  image: absUrl(featuredImage),
  sku: frontmatter.sku || undefined,
  brand: frontmatter.brand || 'Win-Win Stone'
};
---

<BaseLayout
  title={seoTitle}
  description={seoDescription}
>

<ProductHero
  title={title}
  description={description}

  material={material}

  moq={moq}
  leadTime={leadTime}

  categoryLabel={categoryLabel}
  heroBadges={heroBadges}

  featuredImage={featuredImage}
  gallery={gallery}
/>

<section class="product-page">
    <div class="container">
      <nav class="breadcrumb">
        <a href="/">Home</a>
        <span>/</span>
        <a href="/stone-tables/">Stone Tables</a>
        <span>/</span>
        <span>{title}</span>
      </nav>

      <div class="product-grid">
        <div class="product-gallery">
      <div class="gallery-header">


       <h2>
         Material Details & Project Views
      </h2>

      </div>



     <div class="gallery-slider">

      {
       gallery?.map((item) => (

      <a
       href={item.image}
       class="gallery-slide glightbox"
       data-gallery="product-gallery"
      >

          <img
            src={item.image}
            alt={title}
            loading="lazy"
          />

        </a>

       ))
      }

      </div>

    </div>

        
      </div>
    </div>
   </section>

  <ProductFeatures
    features={keyFeatures}
    image={featureImage}
  />


  <ProductSpecifications
    material={material}
    finish={finish}
    moq={moq}
    leadTime={leadTime}
  />
 

  <ProductInquiryCTA
    productTitle={title}
    slug={slug}
  />

  <RelatedProducts
    products={allProducts}
    currentSlug={slug}
    category="stone-sinks"
  />


  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    itemListElement: breadcrumbs.map((b, i) => ({
      "@type": "ListItem",
      position: i + 1,
      name: b.name,
      item: b.url
    }))
  })} />

  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Product",
    name: productForLd.name,
    image: productForLd.image ? [productForLd.image] : undefined,
    sku: productForLd.sku || undefined,
    brand: productForLd.brand ? { "@type": "Brand", name: productForLd.brand } : undefined,
    url: `${siteUrl.replace(/\/$/, '')}/${productForLd.slug.replace(/^\//, '')}`
  })} />



</BaseLayout>

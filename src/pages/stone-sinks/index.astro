---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";

const products = await getCollection("products");
const stoneSinks = products
  .filter(product => product.data.category === "stone-sinks")
  .map(product => ({
    ...product,
    __slug: product.id.split("/").pop()
  }));
---

<BaseLayout
  title="Custom Stone Sinks Manufacturer"
  description="Luxury custom stone sinks including marble pedestal sinks, travertine sinks, and natural stone bathroom basins."
>

<section class="category-hero">
  <div class="container">
    <nav class="breadcrumb">
      <a href="/">Home</a>
      <span>/</span>
      <span>Stone Sinks</span>
    </nav>

    <h1>Custom Stone Sinks</h1>
    <p>Luxury natural stone sink manufacturer for villas, hotels, resorts, and custom bathroom projects.</p>
  </div>
</section>

<section class="category-features">
  <div class="container">
    <h2>Why Choose Our Stone Sinks</h2>
    <div class="features-grid">
      <div class="feature">
        <h3>Premium Materials</h3>
        <p>Sourced from the finest marble, granite, and travertine quarries worldwide</p>
      </div>
      <div class="feature">
        <h3>Expert Craftsmanship</h3>
        <p>Hand-carved by skilled artisans with decades of stone working experience</p>
      </div>
      <div class="feature">
        <h3>Custom Designs</h3>
        <p>Fully customizable shapes, sizes, and finishes for your unique projects</p>
      </div>
      <div class="feature">
        <h3>Luxury & Durability</h3>
        <p>Natural stone with exceptional longevity and timeless beauty</p>
      </div>
    </div>

    <div class="category-intro">
      <h2>Stone Sinks Collection</h2>
      <p>
        Our stone sinks are crafted from premium natural stone materials including marble, 
        granite, and travertine. Each piece is hand-finished to perfection and designed for 
        luxury bathrooms in villas, hotels, resorts, and custom residential projects.
      </p>
      <p>
        Whether you're looking for a classic marble pedestal sink or a custom modern design, 
        we offer infinite customization possibilities to match your interior design vision.
      </p>
    </div>
  </div>
</section>

<section class="product-list-section">
  <div class="container">
    <div class="product-grid">
      {stoneSinks.map((product) => (
        <a href={`/stone-sinks/${product.__slug}/`} class="product-card">
          <div class="product-image">
            <img src={product.data.featuredImage} alt={product.data.title} />
          </div>
          <div class="product-content">
            <h2>{product.data.title}</h2>
            {product.data.material && <p class="material">Material: {product.data.material}</p>}
            <p>{product.data.description}</p>
          </div>
        </a>
      ))}
    </div>

    <div class="related-guides">
      <h3>Related Guides & Resources</h3>
      <ul class="guides-list">
        <li><a href="/stone-furniture-guide/">Stone Bathroom Furniture Guide</a></li>
        <li><a href="/marble-knowledge/">Marble Knowledge & Care</a></li>
        <li><a href="/custom-stone-furniture/">Custom Stone Furniture Solutions</a></li>
      </ul>
    </div>
  </div>
</section>

</BaseLayout>

<style>

.category-hero {
  padding: 80px 0 48px;
}

.breadcrumb {
  display: flex;
  gap: 8px;
  margin-bottom: 24px;
  font-size: 14px;
}

.breadcrumb a {
  color: var(--green);
  text-decoration: none;
}

.category-hero h1 {
  margin-bottom: 20px;
  font-size: 48px;
}

.category-hero p {
  max-width: 720px;
}

.category-features {
  padding: 60px 0;
  background: linear-gradient(135deg, rgba(0,0,0,0.02) 0%, rgba(0,0,0,0.04) 100%);
  margin-bottom: 40px;
}

.category-features h2 {
  text-align: center;
  margin-bottom: 48px;
  font-size: 36px;
}

.features-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
  gap: 32px;
  margin-bottom: 60px;
}

.feature {
  text-align: center;
}

.feature h3 {
  margin-bottom: 12px;
  font-size: 20px;
  color: var(--green);
}

.feature p {
  font-size: 14px;
  color: rgba(0,0,0,0.6);
  line-height: 1.6;
}

.category-intro {
  max-width: 800px;
  margin: 0 auto;
  text-align: center;
}

.category-intro h2 {
  margin-bottom: 20px;
  font-size: 28px;
}

.category-intro p {
  margin-bottom: 16px;
  color: rgba(0,0,0,0.7);
  line-height: 1.7;
}

.product-list-section {
  padding-bottom: 80px;
}

.product-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
  gap: 32px;
  margin-bottom: 60px;
}

.product-card {
  display: block;
  text-decoration: none;
  color: inherit;
  border: 1px solid rgba(0,0,0,0.08);
  transition: transform .2s ease, border-color .2s ease;
}

.product-card:hover {
  transform: translateY(-4px);
  border-color: rgba(0,0,0,0.18);
}

.product-image img {
  width: 100%;
  aspect-ratio: 1 / 1;
  object-fit: cover;
  display: block;
}

.product-content {
  padding: 20px;
}

.product-content h2 {
  margin-bottom: 12px;
  font-size: 22px;
  line-height: 1.3;
}

.product-content .material {
  font-size: 13px;
  color: var(--green);
  margin-bottom: 12px;
  font-weight: 600;
}

.product-content p {
  font-size: 14px;
  color: rgba(0,0,0,0.65);
  line-height: 1.5;
}

.related-guides {
  background: rgba(0,0,0,0.02);
  padding: 40px;
  border-radius: 8px;
  border-left: 4px solid var(--green);
}

.related-guides h3 {
  margin-bottom: 20px;
  font-size: 20px;
  color: var(--green);
}

.guides-list {
  list-style: none;
  padding: 0;
  margin: 0;
  display: flex;
  flex-direction: column;
  gap: 12px;
}

.guides-list li a {
  display: inline-flex;
  align-items: center;
  color: var(--green);
  text-decoration: none;
  font-size: 14px;
  transition: opacity 0.2s ease;
}

.guides-list li a:hover {
  opacity: 0.7;
  text-decoration: underline;
}

</style>

---
import BaseLayout from "../../layouts/BaseLayout.astro";

import ProductHero from "../../components/product/ProductHero.astro";

export async function getStaticPaths() {
  const modules = import.meta.glob("../../content/products/**/*.md", { eager: true });
  return Object.keys(modules)
    .filter(key => key.includes("stone-sinks"))
    .map(key => {
      const slug = key.split("/").pop()?.replace(".md", "");
      return { params: { slug } };
    });
}

const slug = Astro.params.slug;
const modules = import.meta.glob("../../content/products/**/*.md", { eager: true });
const moduleKey = Object.keys(modules).find(key => key.includes(`stone-sinks/${slug}`));

if (!moduleKey) {
  throw Astro.redirect("/404");
}

const module = modules[moduleKey] as { frontmatter: any };
const { frontmatter } = module;
const { title, description, featuredImage, gallery, seoTitle, seoDescription, material,finish,applications,customization,moq,leadtime} = frontmatter;

const siteUrl = import.meta.env.SITE || 'https://winwinstonecustom.com';

function absUrl(path) {
  if (!path) return undefined;
  if (/^https?:\/\//.test(path)) return path;
  return siteUrl.replace(/\/$/, '') + (path.startsWith('/') ? path : '/' + path);
}

const breadcrumbs = [
  { name: 'Home', url: siteUrl + '/' },
  { name: 'Stone Sinks', url: siteUrl + '/stone-sinks/' },
  { name: title, url: `${siteUrl}/stone-sinks/${Astro.params.slug}` }
];

const productForLd = {
  name: title,
  slug: `stone-sinks/${Astro.params.slug}`,
  image: absUrl(featuredImage),
  sku: frontmatter.sku || undefined,
  brand: frontmatter.brand || 'Win-Win Stone'
};

---

<BaseLayout
  title={seoTitle}
  description={seoDescription}
>
<ProductHero
  title={title}
  description={description}
  material={material}
/>

<script type="application/ld+json" set:html={JSON.stringify({
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: breadcrumbs.map((b, i) => ({
    "@type": "ListItem",
    position: i + 1,
    name: b.name,
    item: b.url
  }))
})} />

<script type="application/ld+json" set:html={JSON.stringify({
  "@context": "https://schema.org",
  "@type": "Product",
  name: productForLd.name,
  image: productForLd.image ? [productForLd.image] : undefined,
  sku: productForLd.sku || undefined,
  brand: productForLd.brand ? { "@type": "Brand", name: productForLd.brand } : undefined,
  url: `${siteUrl.replace(/\/$/, '')}/${productForLd.slug.replace(/^\//, '')}`
})} />

<section class="product-page">
  <div class="container">
    <nav class="breadcrumb">
      <a href="/">Home</a>
      <span>/</span>
      <a href="/stone-sinks/">Stone Sinks</a>
      <span>/</span>
      <span>{title}</span>
    </nav>

    <div class="product-grid">
      <div class="product-gallery">
        <img src={featuredImage} alt={title} />
        <div class="gallery-grid">
          {gallery?.map((image) => (
            <img src={image} alt={title} />
          ))}
        </div>
      </div>

      <div class="product-content">

       <h2>
         Product Gallery
       </h2>

       <p>
        Explore detailed views of this custom stone product,
        including material texture, craftsmanship details,
        and project applications.
       </p>

      </div>
    </div>
  </div>
</section>

</BaseLayout>

<style>
.product-page {
  padding: 80px 0;
}

.breadcrumb {
  display: flex;
  gap: 8px;
  margin-bottom: 32px;
  font-size: 14px;
}

.breadcrumb a {
  color: var(--green);
  text-decoration: none;
}

.product-grid {
  display: grid;
  grid-template-columns: 1.2fr 0.8fr;
  gap: 48px;
}

.product-gallery img {
  width: 100%;
  display: block;
}

.gallery-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 12px;
  margin-top: 12px;
}

.product-content {

  display: flex;

  flex-direction: column;

  justify-content: center;
}

.product-content h2 {

  margin-bottom: 20px;

  font-size: 2rem;
}

.product-content p {

  color: var(--muted);

  line-height: 1.8;
}

.product-meta {
  margin-top: 24px;
  font-size: 14px;
  color: rgba(0,0,0,.7);
}
</style>

<section class="material-hero">

  <div class="container">

    <nav class="breadcrumb">

      <a href="/">Home</a>

      <span>/</span>

      <a href="/materials/">Materials</a>

      <span>/</span>

      <span>Calacatta Viola</span>

    </nav>

    <div class="material-hero-grid">

      <div class="material-content">

        <h1>
          Calacatta Viola Marble
        </h1>

        <p>
          Calacatta Viola marble is one of the most recognizable luxury natural
          stones available today. Its dramatic burgundy and purple veining creates
          a striking visual statement while maintaining the timeless elegance
          associated with premium marble.
       </p>

        <p>
          Frequently selected by architects, interior designers and furniture
          brands, Calacatta Viola is suitable for custom stone sinks, dining
          tables, bathtubs, fireplace surrounds and bespoke furniture pieces.
          Widely specified for bathroom interiors and high-end architectural projects.
       </p>

        <Button href="/contact/">
          Request A Quote
        </Button>

        <a
          href="https://wa.me/8613927192948"
          target="_blank"
          rel="noopener noreferrer"
          class="whatsapp-button"
        >
          Chat on WhatsApp
        </a>

      </div>

      <div class="material-image">

        <img
          src="/images/materials/details/calacatta-viola/hero.jpg"
          alt="Calacatta Viola Marble"
        />

      </div>

    </div>

  </div>

</section>




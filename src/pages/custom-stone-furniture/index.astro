---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { customStoneFurnitureData } from "../../data/categories/custom-stone-furniture";
import Hero from "../../components/category/Hero.astro";
import Advantages from "../../components/category/Advantages.astro";
import Customization from "../../components/category/Customization.astro";
import FeaturedProducts from "../../components/category/FeaturedProducts.astro";
import Applications from "../../components/category/Applications.astro";
import FAQ from "../../components/category/FAQ.astro";
import FinalCTA from "../../components/category/FinalCTA.astro";

import { getCollection } from "astro:content";

import {
  buildItemListSchema,
  buildCollectionSchema,
} from "../../lib/schema/category";

const category = "custom-stone-furniture";

const siteUrl = (
  import.meta.env.SITE ??
  "https://www.winwinstonecustom.com"
).replace(/\/$/, "");

// 获取所有产品
const products = await getCollection("products");

// 过滤 Custom Stone Furniture 分类产品
const customStoneFurniture =
  products.filter(
    p => p.data.category === category
  );

const itemListSchema = buildItemListSchema({
  category,
  products: customStoneFurniture,
  baseUrl: siteUrl
});

const collectionSchema = buildCollectionSchema({
  name: "Custom Stone Furniture",
  description:
    "Custom stone furniture from factory.",
  url: `${siteUrl}/custom-stone-furniture/`,
});

---
<BaseLayout
  title="Custom Stone Furniture Manufacturer"
  description="Luxury marble furniture, travertine countertops and custom natural stone fixtures for residential and commercial spaces."
>

  <Hero

  eyebrow="STONE FURNITURE MANUFACTURER"

  title="Custom Stone Furniture"

  description="Premium marble, travertine and natural stone furniture manufactured for villas, hotels, resorts and commercial projects worldwide."

  backgroundImage="/images/categories/custom-stone-furniture-hero.jpg"

/>

  <Advantages
    title={customStoneFurnitureData.advantages.title}
    description={customStoneFurnitureData.advantages.description}
    items={customStoneFurnitureData.advantages.items}
  />
  
  <FeaturedProducts
  products={customStoneFurniture}
  category="custom-stone-furniture"
  title="Explore Our Stone Furniture Collection"
  description="Browse a selection of custom stone furniture manufactured for luxury residential and commercial projects."
  />

  <Customization
    title={customStoneFurnitureData.customization.title}
    description={customStoneFurnitureData.customization.description}
    items={customStoneFurnitureData.customization.items}
  />

  <Applications
    title={customStoneFurnitureData.applications.title}
    description={customStoneFurnitureData.applications.description}
    items={customStoneFurnitureData.applications.items}
  />

  <FAQ
    title={customStoneFurnitureData.faq.title}
    description={customStoneFurnitureData.faq.description}
    items={customStoneFurnitureData.faq.items}
  />

  <FinalCTA
    title={customStoneFurnitureData.cta.title}
    description={customStoneFurnitureData.cta.description}
  />

   <script
    type="application/ld+json"
    set:html={JSON.stringify(itemListSchema)}
   />

  <script
   type="application/ld+json"
   set:html={JSON.stringify(collectionSchema)}
  />
  
</BaseLayout>
---
import BaseLayout from "../../layouts/BaseLayout.astro";

import {stoneBathtubsData} from "../../data/categories/stone-bathtubs";
import Hero from "../../components/category/Hero.astro";
import Advantages from "../../components/category/Advantages.astro";
import Customization from "../../components/category/Customization.astro";
import FeaturedProducts from "../../components/category/FeaturedProducts.astro";
import Applications from "../../components/category/Applications.astro";
import FAQ from "../../components/category/FAQ.astro";
import FinalCTA from "../../components/category/FinalCTA.astro";

import { getCollection } from "astro:content";

import {
  buildItemListSchema,
  buildCollectionSchema,
} from "../../lib/schema/category";


const category = "stone-bathtubs";

const siteUrl = (
  import.meta.env.SITE ??
  "https://www.winwinstonecustom.com"
).replace(/\/$/, "");

// 获取所有产品
const products = await getCollection("products");

// 过滤 Stone Bathtubs 分类产品
const stoneBathtubs = products.filter(
  product => product.data.category === category
);

const itemListSchema = buildItemListSchema({
  category,
  products: stoneBathtubs,
  baseUrl: siteUrl
});

const collectionSchema = buildCollectionSchema({
  name: "Stone Bathtubs",
  description:
    "Luxury marble bathtubs, travertine bathtubs and custom natural stone bathtubs.",
  url: `${siteUrl}/stone-bathtubs/`,
});

---
<BaseLayout
  title="Custom Stone Bathtubs Manufacturer"
  description="Luxury custom stone bathtubs manufactured for residential and commercial projects."
>

<Hero
  eyebrow="STONE BATHTUB MANUFACTURER"
  title="Custom Stone Bathtubs"
  description="Luxury marble and natural stone bathtubs manufactured for villas, hotels, resorts and spa projects worldwide."
  backgroundImage="/images/categories/stone-bathtubs-hero.jpg"
/>

<Advantages
  title={stoneBathtubsData.advantages.title}
  description={stoneBathtubsData.advantages.description}
  items={stoneBathtubsData.advantages.items}
/>
  
<FeaturedProducts
  products={stoneBathtubs}
  category="stone-bathtubs"
  title="Explore Our Stone Bathtub Collection"
  description="Luxury natural stone bathtubs manufactured for villas, hotels and spa projects."
/>
  
<Customization
  title={stoneBathtubsData.customization.title}
  description={stoneBathtubsData.customization.description}
  items={stoneBathtubsData.customization.items}
/>

<Applications
  title={stoneBathtubsData.applications.title}
  description={stoneBathtubsData.applications.description}
  items={stoneBathtubsData.applications.items}
/>

<FAQ
  title={stoneBathtubsData.faq.title}
  description={stoneBathtubsData.faq.description}
  items={stoneBathtubsData.faq.items}
/>

<FinalCTA
  title={stoneBathtubsData.cta.title}
  description={stoneBathtubsData.cta.description}
/>

 <script
  type="application/ld+json"
  set:html={JSON.stringify(itemListSchema)}
  />

  <script
  type="application/ld+json"
  set:html={JSON.stringify(collectionSchema)}
  />

</BaseLayout>
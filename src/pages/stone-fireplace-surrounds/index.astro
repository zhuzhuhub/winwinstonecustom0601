---
import BaseLayout from "../../layouts/BaseLayout.astro";

import { StoneFireplaceSurroundsData } from "../../data/categories/stone-fireplace-surrounds";

import Hero from "../../components/category/Hero.astro";
import Advantages from "../../components/category/Advantages.astro";
import Customization from "../../components/category/Customization.astro";
import FeaturedProducts from "../../components/category/FeaturedProducts.astro";
import Applications from "../../components/category/Applications.astro";
import FAQ from "../../components/category/FAQ.astro";
import FinalCTA from "../../components/category/FinalCTA.astro";

import { getCollection } from "astro:content";

import {
  buildItemListSchema,
  buildCollectionSchema,
} from "../../lib/schema/category";


const category = "stone-fireplace-surrounds";

const siteUrl = (
  import.meta.env.SITE ??
  "https://www.winwinstonecustom.com"
).replace(/\/$/, "");

// 获取所有产品
const products = await getCollection("products");

// 过滤 Stone Fireplace Surrounds 分类产品
const stoneFireplaceSurrounds = products.filter(p => p.data.category === category);

const itemListSchema = buildItemListSchema({
  category,
  products: stoneFireplaceSurrounds,
  baseUrl: siteUrl
});

const collectionSchema = buildCollectionSchema({
  name: "Stone Fireplace Surrounds",
  description:
    "Luxury marble fireplace surrounds and custom natural stone fireplace surrounds.",
  url: `${siteUrl}/stone-fireplace-surrounds/`,
});

---
<BaseLayout
  title="Custom Stone Fireplace Surrounds Manufacturer"
  description="Luxury marble fireplace surrounds, custom stone fireplaces and bespoke fireplace solutions for residential and commercial spaces."
>

 <Hero
  eyebrow="FIREPLACE SURROUND MANUFACTURER"
  title="Custom Fireplace Surrounds"
  description="Luxury marble fireplace surrounds manufactured for villas, hotels and high-end residential interiors."
  backgroundImage="/images/categories/fireplace-surrounds-hero.jpg"
/>

 <Advantages
    title={StoneFireplaceSurroundsData.advantages.title}
    description={StoneFireplaceSurroundsData.advantages.description}
    items={StoneFireplaceSurroundsData.advantages.items}
  />

  <FeaturedProducts
  products={stoneFireplaceSurrounds}
  category="stone-fireplace-surrounds"
  title="Explore Our Stone Fireplace Surround Collection"
  description="Browse a selection of custom stone fireplace surrounds manufactured for luxury residential and commercial projects."
  />
  
  <Customization
    title={StoneFireplaceSurroundsData.customization.title}
    description={StoneFireplaceSurroundsData.customization.description}
    items={StoneFireplaceSurroundsData.customization.items}
  />

  <Applications
    title={StoneFireplaceSurroundsData.applications.title}
    description={StoneFireplaceSurroundsData.applications.description}
    items={StoneFireplaceSurroundsData.applications.items}
  />

  <FAQ
    title={StoneFireplaceSurroundsData.faq.title}
    description={StoneFireplaceSurroundsData.faq.description}
    items={StoneFireplaceSurroundsData.faq.items}
  />

  <FinalCTA
    title={StoneFireplaceSurroundsData.cta.title}
    description={StoneFireplaceSurroundsData.cta.description}
  />

  <script
  type="application/ld+json"
  set:html={JSON.stringify(itemListSchema)}
  />

  <script
  type="application/ld+json"
  set:html={JSON.stringify(collectionSchema)}
  />

</BaseLayout>
---
import "../styles/global.css";

import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

const {
  title = "WIN WIN STONE",
  description = "Custom stone furniture manufacturer",
} = Astro.props;
---

<!doctype html>

<html lang="en">

  <head>

    <meta charset="UTF-8" />

    <meta
      name="viewport"
      content="width=device-width, initial-scale=1"
    />

    <title>{title}</title>

    <meta
      name="description"
      content={description}
    />

  </head>

  <body>

    <Header />

    <main>
      <slot />
    </main>

    <Footer />

  </body>

</html>
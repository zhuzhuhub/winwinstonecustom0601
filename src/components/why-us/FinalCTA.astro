---
import Button from "../Button.astro";
---

<section class="why-cta">

  <div class="container">

    <div class="cta-box">

    

      <h2>
        Ready to Create Your Custom Stone Products?
      </h2>

      <p>
        Whether you need a single prototype,
        a custom furniture collection,
        or large-scale project production,
        our team is ready to help.
      </p>

      <div class="cta-actions">

        <Button
          href="/contact/"
          variant="primary"
          size="large"
        >
          Get A Free Quote
        </Button>

        <Button
          href="/stone-tables/"
          variant="secondary"
          size="large"
        >
          Explore Products
        </Button>

      </div>

    </div>

  </div>

</section>
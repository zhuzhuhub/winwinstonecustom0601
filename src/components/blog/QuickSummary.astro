---
const { items = [] } = Astro.props;
---

<section class="quick-summary">

  <h2>Quick Summary</h2>

  <ul>

    {items.map((item) => {

      // ✅ 兼容旧结构（string）
      if (typeof item === "string") {
        return (
          <li>
            {item}
          </li>
        );
      }

      // ✅ 新结构（object）
      return (
        <li>
          <a href={item.anchor ?? "#"}>
            {item.text ?? item}
          </a>
        </li>
      );

    })}

  </ul>

</section>
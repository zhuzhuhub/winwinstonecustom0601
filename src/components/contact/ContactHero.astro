---
import Button from "../Button.astro";
---

<section class="contact-hero">

  <div class="container">

    <div class="contact-hero-content">

      <span class="contact-eyebrow">
        CONTACT US
      </span>

      <h1>
        Let's Discuss
        Your Stone Project
      </h1>

      <p>

        Whether you need custom stone furniture,
        marble sinks, bathtubs, or architectural
        stone elements, our team is ready to help.

      </p>

      <Button
        href="#inquiry-form"
        variant="primary"
        size="large"
      >
        Send Inquiry
      </Button>

    </div>

  </div>

</section>
---
import SectionHeader from "../SectionHeader.astro";
---

<section class="why-contact-us">

  <div class="container">

    <SectionHeader
    
      title="A Reliable Partner For Stone Projects"
      description="From concept to delivery, our team supports clients with material expertise, manufacturing experience, and responsive communication."
    />

    <div class="contact-benefits">

      <div class="benefit-card">

        <h3>24-Hour Response</h3>

        <p>
          Fast communication and quotation support.
        </p>

      </div>

      <div class="benefit-card">

        <h3>Custom Manufacturing</h3>

        <p>
          Tailored dimensions, materials,
          and finishes.
        </p>

      </div>

      <div class="benefit-card">

        <h3>MOQ From 1 Piece</h3>

        <p>
          Suitable for prototypes and
          project orders.
        </p>

      </div>

      <div class="benefit-card">

        <h3>Global Shipping</h3>

        <p>
          Export experience across
          Europe, North America and beyond.
        </p>

      </div>

    </div>

  </div>

</section>
---
const {
  products = [],
  currentSlug = "",
  category = ""
} = Astro.props;

const relatedProducts = products
  .filter((product: any) => {

    const slug =
      product.file
        ?.split("/")
        ?.pop()
        ?.replace(".md", "");

    return slug !== currentSlug;

  })
  .slice(0, 4);
---

{
  relatedProducts.length > 0 && (

    <section class="related-products">

      <div class="container">

        <div class="section-header">

          <h2>
            You May Also Like
          </h2>

          <p>
            Explore more handcrafted natural stone products.
          </p>

        </div>

        <div class="related-grid">

          {
            relatedProducts.map((product: any) => {

              const slug =
                product.file
                  ?.split("/")
                  .pop()
                  ?.replace(".md", "");

              return (

                <a
                 href={`/${product.frontmatter.category}/${slug}/`}
                 class="related-card"
                >

                <img
                 src={product.frontmatter.featuredImage}
                 alt={product.frontmatter.title}
                 loading="lazy"
                />

                <span 
                 class="related-category">
                 {product.frontmatter.categoryLabel}
               </span>

                <h3>
                 {product.frontmatter.title}
               </h3>

                <span class="related-link">
                 View Details →
               </span>

               </a>
              );

            })
          }

        </div>

      </div>

    </section>

  )
}
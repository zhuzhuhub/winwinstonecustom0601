---
const {
 title,
 description,

 material,
 moq,
 leadTime,

 featuredImage,
 gallery = [],

 categoryLabel,

 heroBadges = []

} = Astro.props;
---

<section class="product-hero">

  <div class="container">

    <div class="product-hero-grid">

      <!-- Left Content -->

      <div class="product-hero-content">

        {
          categoryLabel && (
            <span class="product-eyebrow">
              {categoryLabel}
            </span>
          )
        }

        <h1>
          {title}
        </h1>

        <p class="product-description">
          {description}
        </p>

        <div class="product-badges">

          {heroBadges.map((badge) => (

            <span>{badge}</span>

          ))}

        </div>

        <div class="product-meta">

          <div class="meta-card">

            <span>Material</span>

            <strong>{material}</strong>

          </div>

          <div class="meta-card">

            <span>MOQ</span>

            <strong>{moq}</strong>

          </div>

          <div class="meta-card">

            <span>Lead Time</span>

            <strong>{leadTime}</strong>

          </div>

        </div>

        <div class="hero-actions">

          <a
            href="/contact/"
            class="button button-primary button-large"
         >
            Request Quote
         </a>

         <a
          href="https://wa.me/8613927192948"
          target="_blank"
          rel="noopener noreferrer"
          class="whatsapp-button"
         >
          Chat on WhatsApp
         </a>

        </div>

      </div>

      <!-- Right Image -->

      <div class="product-hero-image">

       <a
        href={featuredImage}
        class="glightbox"
        data-gallery="hero-gallery"
       >

        <img
         src={featuredImage}
         alt={title}
        />

       </a>

       <div class="hero-thumbnails">

        {
          gallery
            .slice(1,5)
            .map((item) => (

              <a
               href={item.image}
               class="glightbox"
               data-gallery="hero-gallery"
              >

               <img
                 src={item.image}
                 alt={title}
               />

             </a>

           ))
        }

      </div>

    </div>

    </div>

  </div>

</section>
---
const {
  features = [],
  image = ""
} = Astro.props;
---

<section class="product-features-v2">

  <div class="container">

    <div class="features-header">


      <h2>
        Why Choose This Stone Product
      </h2>

    </div>

    <div class="features-layout">

      <div class="features-content">

        {
          features.map((item) => (

            <div class="feature-row">

              <h3>
                {item.title}
              </h3>

              <p>
                {item.description}
              </p>

            </div>

          ))
        }

      </div>

      <div class="feature-image">

        <img
          src={image}
          alt="Product Feature"
          loading="lazy"
        />

      </div>

    </div>

  </div>

</section>
---
const {
  material,
  finish,
  moq,
  leadTime
} = Astro.props;

const specs = [
  {
    label: "Material",
    value: material
  },
  {
    label: "Finish",
    value: Array.isArray(finish)
      ? finish.join(" / ")
      : finish
  },
  {
    label: "MOQ",
    value: moq
  },
  {
    label: "Lead Time",
    value: leadTime
  }
];
---

<section class="product-specifications">

  <div class="container">

    <div class="specifications-header">

      <h2>
        Technical Specifications
      </h2>

      <p>
        Essential product information for architects,
        designers, contractors and project buyers.
      </p>

    </div>

    <div class="specifications-table">

      {
        specs.map((spec) => (

          <div class="spec-row">

            <div class="spec-label">
              {spec.label}
            </div>

            <div class="spec-value">
              {spec.value}
            </div>

          </div>

        ))
      }

    </div>

  </div>

</section>
---
import SectionHeader from "../common/SectionHeader.astro";

const {
  title = "Frequently Asked Questions",
  description = "",
  items = []
} = Astro.props;
---

<section class="category-faq">

  <div class="container">

    <SectionHeader
      title={title}
      description={description}
    />

    <div class="faq-list">

      {items.map((item) => (

        <div class="faq-item">

          <h3>
            {item.question}
          </h3>

          <p>
            {item.answer}
          </p>

        </div>

      ))}

    </div>

  </div>

</section>
---
import SectionHeader from "../common/SectionHeader.astro";
---

<section class="category-customization">

  <div class="container">

    <SectionHeader
      eyebrow="CUSTOM SOLUTIONS"
      title="Customization Options"
      description="Every stone sink can be customized to match your project requirements."
    />

    <div class="customization-grid">

      <div class="custom-card">

        <h3>
          Size & Dimensions
        </h3>

        <p>
          Custom width, depth, height,
          basin dimensions, and installation
          requirements.
        </p>

      </div>

      <div class="custom-card">

        <h3>
          Stone Materials
        </h3>

        <p>
          Marble, travertine, limestone,
          granite, quartzite, and other
          natural stones.
        </p>

      </div>

      <div class="custom-card">

        <h3>
          Surface Finishes
        </h3>

        <p>
          Polished, honed, brushed,
          leathered, sandblasted,
          and antique finishes.
        </p>

      </div>

      <div class="custom-card">

        <h3>
          Design Details
        </h3>

        <p>
          Fluted designs, edge profiles,
          drain locations, and bespoke
          decorative features.
        </p>

      </div>

    </div>

  </div>

</section>
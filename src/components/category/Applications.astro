---
import SectionHeader from "../common/SectionHeader.astro";
---

<section class="category-applications">

  <div class="container">

    <SectionHeader
      eyebrow="APPLICATIONS"
      title="Suitable For Various Projects"
      description="Our custom stone sinks are widely used in residential and commercial projects worldwide."
    />

    <div class="applications-grid">

      <div class="application-card">

        <h3>
          Luxury Villas
        </h3>

        <p>
          Premium stone sinks designed for
          high-end residential bathrooms and
          bespoke interior projects.
        </p>

      </div>

      <div class="application-card">

        <h3>
          Hotels & Resorts
        </h3>

        <p>
          Durable and elegant solutions for
          luxury hospitality developments and
          guest bathroom spaces.
        </p>

      </div>

      <div class="application-card">

        <h3>
          Apartments & Condominiums
        </h3>

        <p>
          Custom sink solutions for modern
          residential developments and
          premium living environments.
        </p>

      </div>

      <div class="application-card">

        <h3>
          Commercial Projects
        </h3>

        <p>
          Stone sinks suitable for commercial
          washrooms, clubs, spas, and
          architectural projects.
        </p>

      </div>

    </div>

  </div>

</section>
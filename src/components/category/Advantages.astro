---
import SectionHeader from "../common/SectionHeader.astro";
---

<section class="category-advantages">

  <div class="container">

    <SectionHeader
      eyebrow="WHY CHOOSE US"
      title="Why Choose Our Custom Stone Sinks"
      description="Designed for architects, designers, wholesalers, and luxury bathroom projects worldwide."
    />

    <div class="advantages-grid">

      <div class="advantage-card">

        <h3>
          Premium Natural Stone
        </h3>

        <p>
          Carefully selected marble, travertine,
          limestone, and granite materials from
          trusted quarries.
        </p>

      </div>

      <div class="advantage-card">

        <h3>
          Fully Customizable
        </h3>

        <p>
          Custom dimensions, basin depth,
          edge profiles, finishes, and drainage
          positions available.
        </p>

      </div>

      <div class="advantage-card">

        <h3>
          Handcrafted Quality
        </h3>

        <p>
          Manufactured by experienced stone
          craftsmen with strict quality control
          throughout production.
        </p>

      </div>

      <div class="advantage-card">

        <h3>
          Global Project Experience
        </h3>

        <p>
          Exporting stone sinks for villas,
          hotels, resorts, and commercial
          projects worldwide.
        </p>

      </div>

    </div>

  </div>

</section>
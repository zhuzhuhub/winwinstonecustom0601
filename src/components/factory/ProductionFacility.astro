---
import SectionHeader from "../SectionHeader.astro";
---

<section class="production-facility">

  <div class="container">

    <SectionHeader
      title="Craftsmanship & Finishing Expertise"
      description="Combining advanced fabrication techniques with experienced craftsmanship to create custom stone products with refined details and premium finishes."
    />

    <div class="facility-grid">

      <article class="facility-card">

        <img
          src="/images/factory/craftsmanship-edge-profiling.jpg"
          alt="Stone Edge Profiling"
        />

        <div class="facility-content">

          <h3>Edge Profiling</h3>

          <p>
            Custom edge treatments for tables,
            countertops, vanities, and furniture pieces.
          </p>

        </div>

      </article>

      <article class="facility-card">

        <img
          src="/images/factory/craftsmanship-fluted-surface.jpg"
          alt="Fluted Stone Surface"
        />

        <div class="facility-content">

          <h3>Fluted & Textured Surfaces</h3>

          <p>
            Decorative grooves, fluted details,
            and architectural surface treatments.
          </p>

        </div>

      </article>

      <article class="facility-card">

        <img
          src="/images/factory/craftsmanship-hand-finishing.jpg"
          alt="Hand Finishing"
        />

        <div class="facility-content">

          <h3>Hand Finishing</h3>

          <p>
            Refined craftsmanship that enhances
            the natural beauty of every stone piece.
          </p>

        </div>

      </article>

      <article class="facility-card">

        <img
          src="/images/factory/craftsmanship-bookmatch-marble.jpg"
          alt="Bookmatch Marble"
        />

        <div class="facility-content">

          <h3>Bookmatching & Vein Alignment</h3>

          <p>
            Careful slab selection and layout
            for seamless visual continuity.
          </p>

        </div>

      </article>

    </div>

  </div>

</section>
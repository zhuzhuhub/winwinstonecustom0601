---
import SectionHeader from "../SectionHeader.astro";
---

<section class="production-facility">

  <div class="container">

    <SectionHeader
     
      title="Advanced Equipment For Precision Manufacturing"
      description="Our workshop combines modern stone fabrication technology with experienced craftsmanship to deliver consistent quality at scale."
    />

    <div class="facility-grid">

      <div class="facility-card">
        <h3>CNC Machining</h3>
        <p>
          Precision shaping and complex stone fabrication.
        </p>
      </div>

      <div class="facility-card">
        <h3>Bridge Saw Cutting</h3>
        <p>
          Accurate slab processing for custom projects.
        </p>
      </div>

      <div class="facility-card">
        <h3>Waterjet Cutting</h3>
        <p>
          Detailed patterns and intricate stone designs.
        </p>
      </div>

      <div class="facility-card">
        <h3>Polishing Lines</h3>
        <p>
          Consistent finishes across production batches.
        </p>
      </div>

    </div>

  </div>

</section>
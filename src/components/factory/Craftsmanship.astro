---
import SectionHeader from "../SectionHeader.astro";
---

<section class="craftsmanship">

  <div class="container">

    <SectionHeader
     
      title="Where Technology Meets Skilled Handcraft"
      description="Beyond machinery, every project benefits from experienced artisans who refine details, finishes, and stone character by hand."
    />

    <div class="craft-grid">

      <div class="craft-card">

        <h3>Edge Profiling</h3>

        <p>
          Custom edge details crafted for furniture,
          sinks, and architectural stone projects.
        </p>

      </div>

      <div class="craft-card">

        <h3>Hand Finishing</h3>

        <p>
          Skilled polishing and surface refinement
          for premium visual quality.
        </p>

      </div>

      <div class="craft-card">

        <h3>Fluted Detailing</h3>

        <p>
          Precision grooves and decorative textures
          for bespoke designs.
        </p>

      </div>

      <div class="craft-card">

        <h3>Bookmatching</h3>

        <p>
          Careful slab selection to achieve
          symmetrical natural stone patterns.
        </p>

      </div>

    </div>

  </div>

</section>
---
import SectionHeader from "../SectionHeader.astro";
---

<section class="materials-section">

  <div class="container">

    <SectionHeader
     
      title="Premium Natural Stone Selection"
      description="We work with carefully selected natural stones to meet the aesthetic, functional, and technical requirements of each project."
    />

    <div class="materials-grid">

      <div class="material-card">

        <h3>Marble</h3>

        <p>
          Elegant veining and timeless appeal
          for luxury interiors and furniture.
        </p>

      </div>

      <div class="material-card">

        <h3>Travertine</h3>

        <p>
          Warm textures and architectural
          character for contemporary spaces.
        </p>

      </div>

      <div class="material-card">

        <h3>Limestone</h3>

        <p>
          Natural softness and refined
          appearance for custom projects.
        </p>

      </div>

      <div class="material-card">

        <h3>Granite</h3>

        <p>
          Exceptional durability for
          demanding residential and commercial use.
        </p>

      </div>

      <div class="material-card">

        <h3>Onyx</h3>

        <p>
          Unique translucency and dramatic
          visual impact for statement pieces.
        </p>

      </div>

      <div class="material-card">

        <h3>Custom Sourcing</h3>

        <p>
          Special stone requests sourced
          according to project requirements.
        </p>

      </div>

    </div>

  </div>

</section>
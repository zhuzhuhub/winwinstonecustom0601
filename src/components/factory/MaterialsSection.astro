---
import SectionHeader from "../SectionHeader.astro";
---

<section class="materials-section">

  <div class="container">

    <SectionHeader

      title="Choosing The Right Material For Each Project"

      description="Material selection plays an important role in the success of a custom stone project. We help clients evaluate aesthetics, application requirements, availability, and budget considerations."

    />

    <div class="material-selection-grid">

      <div class="selection-card">

        <h3>Aesthetic Goals</h3>

        <p>
          Match the stone's color, texture,
          and character with the project's
          overall design vision.
        </p>

      </div>

      <div class="selection-card">

        <h3>Application Requirements</h3>

        <p>
          Different applications require
          different performance characteristics
          and fabrication approaches.
        </p>

      </div>

      <div class="selection-card">

        <h3>Material Availability</h3>

        <p>
          Consider slab availability,
          lead times, and production schedules
          during planning.
        </p>

      </div>

      <div class="selection-card">

        <h3>Budget Considerations</h3>

        <p>
          Balance appearance, performance,
          and budget expectations to find
          the most suitable solution.
        </p>

      </div>

    </div>

    <div class="materials-library">

      <h3>Explore Material Options</h3>

      <div class="materials-grid">

        <a href="/materials/" class="material-card">

          <img
            src="/images/materials/travertine.jpg"
            alt="Travertine"
          />

          <span>Travertine</span>

        </a>

        <a href="/materials/" class="material-card">

          <img
            src="/images/materials/marble.jpg"
            alt="Marble"
          />

          <span>Marble</span>

        </a>

        <a href="/materials/" class="material-card">

          <img
            src="/images/materials/limestone.jpg"
            alt="Limestone"
          />

          <span>Limestone</span>

        </a>

        <a href="/materials/" class="material-card">

          <img
            src="/images/materials/onyx.jpg"
            alt="Onyx"
          />

          <span>Onyx</span>

        </a>

         <a href="/materials/" class="material-card">

          <img
            src="/images/materials/luxury-stone.jpg"
            alt="Luxury Stone Collection"
          />

          <span>More Materials Available</span>

         </a>

      </div>

    </div>

  </div>

</section>
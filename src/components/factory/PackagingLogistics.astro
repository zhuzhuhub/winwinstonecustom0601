---
import SectionHeader from "../SectionHeader.astro";
---

<section class="packaging-logistics">

  <div class="container">

    <SectionHeader
      title="Packaging & Logistics"
      description="Every custom stone product is inspected, protected, and prepared for international transportation with export-oriented packaging solutions."
      align="center"
    />

    <div class="logistics-grid">

      <article class="logistics-card">

        <img
          src="/images/factory/factory-inspection.jpg"
          alt="Quality Inspection"
        />

        <div class="logistics-content">

          <h3>Quality Inspection</h3>

          <p>
            Verification of dimensions,
            finishes, and specifications
            before shipment.
          </p>

        </div>

      </article>

      <article class="logistics-card">

        <img
          src="/images/factory/factory-packaging.jpg"
          alt="Protective Packaging"
        />

        <div class="logistics-content">

          <h3>Protective Packaging</h3>

          <p>
            Foam, corner protection,
            and secure wrapping
            for fragile stone products.
          </p>

        </div>

      </article>

      <article class="logistics-card">

        <img
          src="/images/factory/factory-crating.jpg"
          alt="Wooden Crates"
        />

        <div class="logistics-content">

          <h3>Export Crating</h3>

          <p>
            Reinforced wooden crates
            designed for international
            transportation.
          </p>

        </div>

      </article>

      <article class="logistics-card">

        <img
          src="/images/factory/factory-shipping.jpg"
          alt="Container Loading"
        />

        <div class="logistics-content">

          <h3>Global Shipping</h3>

          <p>
            Container loading support
            and export coordination
            for worldwide delivery.
          </p>

        </div>

      </article>

    </div>

  </div>

</section>
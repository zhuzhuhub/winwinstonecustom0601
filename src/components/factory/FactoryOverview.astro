---
import SectionHeader from "../SectionHeader.astro";
---

<section class="factory-overview">

  <div class="container">

    <SectionHeader
      title="Specialized Production Capabilities"
      description="Dedicated manufacturing resources for different product categories, ensuring appropriate fabrication methods, craftsmanship, and quality standards for every project."
      align="center"
    />

    <div class="factory-grid">

      <!-- Stone Sinks -->

      <article class="factory-item">

        <img
          src="/images/factory/factory-sinks.jpg"
          alt="Stone Sink Manufacturing"
        />

        <div class="factory-content">

          <h3>Stone Sinks</h3>

          <p>
            Custom pedestal sinks, vessel sinks,
            and integrated bathroom solutions
            manufactured with precision stone fabrication.
          </p>

        </div>

      </article>

      <!-- Stone Tables -->

      <article class="factory-item">

        <img
          src="/images/factory/factory-tables.jpg"
          alt="Stone Table Manufacturing"
        />

        <div class="factory-content">

          <h3>Stone Tables</h3>

          <p>
            Dining tables, coffee tables,
            side tables, and bespoke furniture
            crafted for residential and hospitality projects.
          </p>

        </div>

      </article>

      <!-- Custom Furniture -->

      <article class="factory-item">

        <img
          src="/images/factory/factory-custom.jpg"
          alt="Custom Stone Furniture"
        />

        <div class="factory-content">

          <h3>Custom Stone Furniture</h3>

          <p>
            Tailor-made stone furniture
            produced according to client drawings,
            concepts, and project requirements.
          </p>

        </div>

      </article>

      <!-- Architectural Stone -->

      <article class="factory-item">

        <img
          src="/images/factory/factory-architectural.jpg"
          alt="Architectural Stone Fabrication"
        />

        <div class="factory-content">

          <h3>Architectural Stone</h3>

          <p>
            Fireplace surrounds, wall cladding,
            feature elements, and custom architectural
            stone solutions.
          </p>

        </div>

      </article>

    </div>

  </div>

</section>
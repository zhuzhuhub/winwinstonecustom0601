---
import SectionHeader from "../SectionHeader.astro";
---

<section class="factory-overview">

  <div class="container">

    <!-- Section Header -->
    <SectionHeader
     
      title="Built For Custom Stone Manufacturing"
      description="From marble pedestal sinks to large-scale hospitality furniture, our facility is equipped to handle custom production with precision and consistency."
      align="center"
    />

    <!-- Factory Stats Cards -->
    <div class="factory-stats">

      <div class="factory-card">
        <span class="factory-number">10,000㎡</span>
        <span class="factory-label">Workshop</span>
      </div>

      <div class="factory-card">
        <span class="factory-number">50+</span>
        <span class="factory-label">Skilled Craftsmen</span>
      </div>

      <div class="factory-card">
        <span class="factory-number">15+</span>
        <span class="factory-label">Years Experience</span>
      </div>

      <div class="factory-card">
        <span class="factory-number">30+</span>
        <span class="factory-label">Export Countries</span>
      </div>

    </div>

  </div>

</section>
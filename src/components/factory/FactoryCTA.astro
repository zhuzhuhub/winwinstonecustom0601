---
import Button from "../Button.astro";
---

<section class="factory-cta">

  <div class="container">

    <div class="factory-cta-box">


      <h2>
        Send Your Drawings For Review
      </h2>

      <p>
        Whether you have technical drawings,
        concept sketches, reference images,
        or material requirements, our team can
        review your project and provide
        fabrication recommendations.
      </p>

      <div class="factory-cta-features">

        <span>✓ Drawing Review</span>

        <span>✓ Material Suggestions</span>

        <span>✓ Production Assessment</span>

        <span>✓ Quotation Support</span>

      </div>

      <div class="factory-cta-actions">

        <Button
          href="/contact/"
          variant="primary"
          size="large"
        >
          Get A Free Quote
        </Button>

          <a
          href="https://wa.me/8613927192948"
          target="_blank"
          rel="noopener noreferrer"
          class="whatsapp-button"
        >
          Chat on WhatsApp
        </a>
        

      </div>

    </div>

  </div>

</section>
---
import SectionHeader from "../SectionHeader.astro";
---

<section class="manufacturing-process">

  <div class="container">

    <SectionHeader
    
      title="From Stone Block To Finished Product"
      description="Every project follows a structured manufacturing process to ensure consistency, quality, and precision."
    />

    <div class="process-grid">

      <div class="process-step">

        <span class="process-number">01</span>

        <h3>Stone Selection</h3>

        <p>
          Carefully choosing slabs based on
          color, veining, and project requirements.
        </p>

      </div>

      <div class="process-step">

        <span class="process-number">02</span>

        <h3>Cutting</h3>

        <p>
          Precision cutting using bridge saws
          and CNC equipment.
        </p>

      </div>

      <div class="process-step">

        <span class="process-number">03</span>

        <h3>Fabrication</h3>

        <p>
          Shaping, profiling, carving,
          and assembly work.
        </p>

      </div>

      <div class="process-step">

        <span class="process-number">04</span>

        <h3>Finishing</h3>

        <p>
          Honed, polished, brushed,
          or custom surface treatments.
        </p>

      </div>

      <div class="process-step">

        <span class="process-number">05</span>

        <h3>Inspection</h3>

        <p>
          Dimension checks and
          visual quality verification.
        </p>

      </div>

      <div class="process-step">

        <span class="process-number">06</span>

        <h3>Packing</h3>

        <p>
          Export-grade protection
          and wooden crate packaging.
        </p>

      </div>

    </div>

  </div>

</section>
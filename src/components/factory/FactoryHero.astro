---
import heroImage from "../../assets/factory/factory-hero.jpg";

import Button from "../Button.astro";
---

<section
  class="factory-hero"
  style={`background-image:url(${heroImage.src})`}
>

  <div class="factory-overlay"></div>

  <div class="container factory-container">

    <div class="factory-content">


      <h1>
        Manufacturing Excellence Powered by Industry Resources
      </h1>

      <p class="factory-description">
        Based in one of the world's leading stone production regions,
        we collaborate with specialized workshops and manufacturing partners
        to deliver custom stone solutions for projects worldwide.
      </p>

      <p class="factory-description">
        From raw stone blocks to finished furniture,
        every piece is crafted through advanced
        fabrication, skilled craftsmanship, and
        strict quality control.

      </p>

      <div class="factory-actions">

        <Button
          href="/contact/"
          variant="primary"
          size="large"
        >
          Start Your Project
        </Button>
        
        <a
          href="https://wa.me/8613927192948"
          target="_blank"
          rel="noopener noreferrer"
          class="whatsapp-button"
        >
          Chat on WhatsApp
        </a>
        
      </div>

      <div class="factory-points">

        <div>
          Material Resources
        </div>

        <div>
          Skilled Craftsmanship
        </div>

         <div>
          Advanced Processing
        </div>

        <div>
          Export Experience
        </div>

      </div>

    </div>

  </div>

</section>
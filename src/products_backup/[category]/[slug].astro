---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

export async function getStaticPaths() {
  const allProducts = await getCollection("products");
  return allProducts.map((entry) => ({
    params: {
      category: entry.data.category,
      slug: entry.id.split("/").pop(),
    },
  }));
}

const { category, slug } = Astro.params;
const products = await getCollection("products");
const product = products.find((entry) => entry.id.split("/").pop() === slug && entry.data.category === category);

if (!product) {
  throw new Error(`Product not found: ${category}/${slug}`);
}

const { title, description, featuredImage, gallery, material, seoTitle, seoDescription } = product.data;

const productSchema = {
  "@context": "https://schema.org",
  "@type": "Product",
  name: title,
  description,
  image: [featuredImage, ...(gallery || [])],
  manufacturer: {
    "@type": "Organization",
    name: "Win-Win Stone",
  },
  brand: {
    "@type": "Brand",
    name: "Win-Win Stone",
  },
};
---

<BaseLayout
  title={seoTitle ?? title}
  description={seoDescription ?? description}
>
  <script type="application/ld+json" set:html={JSON.stringify(productSchema)} />

  <section class="product-page">
    <div class="container">
      <nav class="breadcrumb">
        <a href="/">Home</a>
        <span>/</span>
        <a href="/products/">Products</a>
        <span>/</span>
        <a href={`/products/${category}/`}>
          {category.replace(/-/g, " ")}
        </a>
        <span>/</span>
        <span>{title}</span>
      </nav>

      <div class="product-grid">
        <div class="product-gallery">
          <img src={featuredImage} alt={title} />
          {gallery?.length ? (
            <div class="gallery-grid">
              {gallery.map((image) => (
                <img src={image} alt={title} />
              ))}
            </div>
          ) : null}
        </div>

        <div class="product-content">
          <h1>{title}</h1>
          <p>{description}</p>
          {material ? (
            <div class="product-meta">
              <strong>Material:</strong>
              {material}
            </div>
          ) : null}
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
.product-page {
  padding: 80px 0;
}
.breadcrumb {
  display: flex;
  gap: 8px;
  margin-bottom: 32px;
  font-size: 14px;
}
.breadcrumb a {
  color: var(--green);
  text-decoration: none;
}
.product-grid {
  display: grid;
  grid-template-columns: 1.2fr 0.8fr;
  gap: 48px;
}
.product-gallery img {
  width: 100%;
  display: block;
}
.gallery-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 12px;
  margin-top: 12px;
}
.product-content h1 {
  margin-bottom: 24px;
}
.product-meta {
  margin-top: 24px;
  font-size: 14px;
  color: rgba(0,0,0,.7);
}
</style>
